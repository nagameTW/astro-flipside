---
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";
import Layout from "@/layouts/Layout.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import Toc from "@/components/Toc.astro";
import Comments from "@/components/Comments.astro";
import { t, fill } from "@/locales";
import { resolveImg, url } from "@/utils/url";
import SITE from "@/config";
// The byline wears the WORK avatar: posts are the musician identity's
// output (the Life face's cat stays on the about page).
import { AVATAR_WORK } from "@/data/about";

type Props = CollectionEntry<"blog">["data"] & {
  minutesRead: number;
  headings: MarkdownHeading[];
  prev?: { id: string; title: string };
  next?: { id: string; title: string };
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  draft,
  minutesRead,
  headings,
  prev,
  next,
} = Astro.props;
// Same h2/h3 + footnote-label exclusion as Toc.astro: when the ToC would
// render nothing, skip the .post-body grid entirely — an empty rail would
// still reserve its 220px desktop column (squeezing the prose) and add a
// stray grid gap on mobile.
const hasToc = headings.some(
  (h) => (h.depth === 2 || h.depth === 3) && h.slug !== "footnote-label",
);
---

<Layout title={title} description={description}>
  <article class="ts-container is-narrow" data-pagefind-body>
    <header class="post-header">
      <a class="post-back" href={url("/blog/")}>
        <span class="ts-icon is-arrow-left-icon" aria-hidden="true"></span>
        {t["post.backToList"]}
      </a>
      <h1 class="ts-header is-big is-heavy post-title">{title}</h1>
      {
        draft && (
          // Dev-only signal: getPosts() filters drafts out of prod builds,
          // so this chip can never render in a production build.
          <span class="ts-chip is-outlined has-top-spaced">
            {t["blog.draft"]}
          </span>
        )
      }
      <div class="post-meta">
        <img class="post-meta-avatar" src={url(AVATAR_WORK)} alt="" />
        <div class="post-meta-who">
          <div class="post-meta-author">{SITE.author}</div>
          <div class="ts-text is-description">
            <FormattedDate date={pubDate} />
            {
              updatedDate && (
                <>
                  {` · ${t["blog.updated"]} `}
                  <FormattedDate date={updatedDate} />
                </>
              )
            }
            {` · ${fill(t["blog.readingTime"], { m: minutesRead })}`}
          </div>
        </div>
      </div>
    </header>
    {
      heroImage && (
        <img
          class="post-hero"
          src={resolveImg(heroImage)}
          alt=""
          fetchpriority="high"
        />
      )
    }
    {
      hasToc ? (
        <div class="post-body">
          <div class="md-content">
            <slot />
          </div>
          <aside class="post-rail">
            <Toc headings={headings} />
          </aside>
        </div>
      ) : (
        <div class="md-content">
          <slot />
        </div>
      )
    }
    {
      tags.length > 0 && (
        <div class="ts-wrap post-tags">
          {tags.map((tag) => (
            <a
              href={url(`/blog/tags/${tag}/`)}
              class="ts-chip is-circular is-outlined"
            >
              {tag}
            </a>
          ))}
        </div>
      )
    }
    {
      (prev || next) && (
        <nav class="cards-grid post-nav">
          {(
            [
              { rel: "prev", label: t["blog.prev"], post: prev },
              { rel: "next", label: t["blog.next"], post: next },
            ] as const
          ).map(
            ({ rel, label, post }) =>
              post && (
                <a class="ts-box" rel={rel} href={url(`/blog/${post.id}/`)}>
                  <div class="ts-content">
                    <div class="ts-text is-description">{label}</div>
                    <div class="ts-header is-heavy">{post.title}</div>
                  </div>
                </a>
              ),
          )}
        </nav>
      )
    }
    <Comments />
  </article>
</Layout>
