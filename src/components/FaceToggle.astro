---
// The Work/Life switch: one button, slash-divided labels, the active side
// dark and the idle side faint (styled after mlgzackfly.tw's 中/EN language
// switcher). Each face embeds a copy in its identity card — the card is
// sticky, so an outside overlay could not track it — and the toggle script
// in index.astro syncs every copy, so both ship with the default (personal)
// state: showing Life, one click away from Work.
import { t, fill } from "@/locales";
---

<button
  type="button"
  class="face-toggle"
  aria-label={fill(t["face.switchTo"], { name: t["face.work"] })}
>
  <span class="face-option" data-face="professional">{t["face.work"]}</span>
  <span class="face-divider" aria-hidden="true">/</span>
  <span class="face-option is-active" data-face="personal"
    >{t["face.life"]}</span
  >
</button>
