---
// Shared by blog/[...page].astro and blog/tags/[tag]/[...page].astro.
// Mirrors the source site's zeroday pagination markup (.pagination-wrap +
// ts-pagination): back arrow, one numbered item per page, next arrow.
import type { Page } from "astro";
import { t } from "@/locales";

interface Props {
  page: Page<unknown>;
}

const { page } = Astro.props;

// The listing root every page link hangs off: page 1's own URL IS the root,
// deeper pages end in /<currentPage>. Deriving it from page.url.current
// keeps this component free of per-listing props and base-path handling —
// it works for both /blog and /blog/tags/<tag>.
const root =
  page.currentPage === 1
    ? page.url.current.replace(/\/$/, "")
    : page.url.current.replace(new RegExp(`/${page.currentPage}/?$`), "");
const pageHref = (n: number) => (n === 1 ? root : `${root}/${n}`);
---

{
  page.lastPage > 1 && (
    <div class="pagination-wrap">
      <nav class="ts-pagination" aria-label={t["pagination.label"]}>
        {page.url.prev && (
          <a
            class="item is-back"
            href={page.url.prev}
            aria-label={t["pagination.prev"]}
          />
        )}
        {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((n) => (
          <a
            class:list={["item", { "is-active": n === page.currentPage }]}
            href={pageHref(n)}
            aria-current={n === page.currentPage ? "page" : undefined}
          >
            {n}
          </a>
        ))}
        {page.url.next && (
          <a
            class="item is-next"
            href={page.url.next}
            aria-label={t["pagination.next"]}
          />
        )}
      </nav>
    </div>
  )
}
