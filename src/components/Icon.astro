---
// Inline SVG icons — replaces the Font Awesome icon-font subset Tocas ships
// (~270 KB of woff2 for ~20 glyphs). The name→path map and the IconName type
// live in ./icons.ts; add new glyphs there.
//
// Heads-up if you add Tocas components the template doesn't use (checkbox,
// select, rating, breadcrumb…): their built-in glyphs were icon-font
// pseudo-elements, and the font is gone — supply the glyph with <Icon>
// the same way Pagination.astro does.
import { ICONS, type IconName } from "./icons";

interface Props {
  name: IconName;
  class?: string;
}

const { name, class: cls } = Astro.props;
const def = ICONS[name];
if (!def) {
  throw new Error(
    `Unknown icon "${name}" — add it to ICONS in src/components/icons.ts`,
  );
}
const [width, path] = def;
---

<!-- width 1.18em mirrors Tocas's .ts-icon glyph box so swapped icons keep
     their old horizontal footprint; height 1em + baseline shift in global.css -->
<svg
  class:list={["icon", cls]}
  viewBox={`0 0 ${width} 512`}
  width="1.18em"
  height="1em"
  fill="currentColor"
  aria-hidden="true"><path d={path}></path></svg
>
