---
// Comments.astro — giscus (GitHub Discussions-backed comments), gated behind
// SITE.features.giscus. giscus is the one deliberate third-party embed in
// this template (it IS the feature the no-CDN rule doesn't apply to); every
// other asset in the site ships from our own build.
//
// The embed script below is `is:inline`: Astro never hoists or bundles it,
// so a static `{g && <Comments />}` import in BlogPost.astro can't leak
// anything into the Vite graph when the flag is off.
//
// The script tag below is a sibling of the conditional section markup, not
// nested inside it, and always renders; `if (!g) return;` is the actual
// on/off switch. That's safe because Astro wraps every define:vars script
// body in an IIFE (confirmed against built dist output), so the guard runs
// in real function scope. The previous shape — the script tag nested inside
// `{g && (...)}`, plus a stray literal mention of the tag name earlier in
// this very comment block — made Vite's cold-start dependency scan (a
// regex-based pass over the raw file text, not a real parse) misidentify
// where the script starts and print a harmless-but-scary ERROR on every
// `npm run dev`; this shape, keeping the comments free of that literal
// substring, doesn't trip it. Trade-off: flag off, the guarded script's own
// dead source still ships as inert text (grep -ri giscus dist/ now finds
// it), but nothing executes past the guard — no request to giscus.app, no
// third-party code runs.
//
// data-* attributes go through `.dataset` rather than a setAttribute loop:
// simpler, and it's a native property assignment instead of a quoted-key
// object literal.
import SITE from "@/config";
const g = SITE.features.giscus;
---

{
  g && (
    <section class="comments has-top-spaced">
      <div id="giscus" />
    </section>
  )
}
<script is:inline define:vars={{ g }}>
  if (!g) return;
  const dark = () =>
    document.documentElement.classList.contains("is-dark") ||
    (!document.documentElement.classList.contains("is-light") &&
      matchMedia("(prefers-color-scheme: dark)").matches);
  const s = document.createElement("script");
  s.src = "https://giscus.app/client.js";
  s.dataset.repo = g.repo;
  s.dataset.repoId = g.repoId;
  s.dataset.category = g.category;
  s.dataset.categoryId = g.categoryId;
  s.dataset.mapping = "pathname";
  s.dataset.reactionsEnabled = "1";
  s.dataset.inputPosition = "bottom";
  s.dataset.lang = document.documentElement.lang;
  s.dataset.theme = dark() ? "dark" : "light";
  s.crossOrigin = "anonymous";
  s.async = true;
  document.getElementById("giscus").appendChild(s);
  window.addEventListener("themechange", () => {
    document
      .querySelector("iframe.giscus-frame")
      ?.contentWindow?.postMessage(
        { giscus: { setConfig: { theme: dark() ? "dark" : "light" } } },
        "https://giscus.app",
      );
  });
</script>
