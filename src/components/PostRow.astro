---
// One post in the blog list — Medium-style row, not a card: text on the
// left (title, description, date), square-ish cover on the right, and
// the list draws a rule between rows. The whole row is the link.
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";
import SmartImage from "@/components/SmartImage.astro";
import { url } from "@/utils/url";

interface Props {
  post: CollectionEntry<"blog">;
  /** First row above the fold: fetch its cover eagerly. */
  eager?: boolean;
}
const { post, eager = false } = Astro.props;
---

<article class="post-row">
  <a class="post-row-main" href={url(`/blog/${post.id}/`)}>
    <div class="post-row-text">
      <h2 class="post-row-title">{post.data.title}</h2>
      {
        post.data.description && (
          <p class="ts-text is-secondary">{post.data.description}</p>
        )
      }
      <div class="ts-text is-description">
        <FormattedDate date={post.data.pubDate} />
      </div>
    </div>
    {
      post.data.heroImage && (
        <SmartImage
          class="post-row-cover"
          src={post.data.heroImage}
          alt=""
          loading={eager ? "eager" : "lazy"}
          fetchpriority={eager ? "high" : undefined}
          widths={[320, 640]}
          sizes="(max-width: 640px) 96px, 176px"
        />
      )
    }
  </a>
</article>
