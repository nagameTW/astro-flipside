---
// A landing list section: sticky bilingual eyebrow on the left (big English
// word + localized descriptor), a column of <LandingRow>s in the slot, and
// a "view all" link bottom-right. Shared by the Blog and Projects previews;
// Gallery (a photo strip) and About (stacked, no view-all) keep their own
// markup in index.astro because their bodies differ.
import { t } from "@/locales";

interface Props {
  /** Big English eyebrow — pass a locale string. */
  eyebrow: string;
  /** Localized sub-label under the eyebrow. */
  descriptor: string;
  /** "View all" target — an absolute href already run through url(). */
  viewAll: string;
}
const { eyebrow, descriptor, viewAll } = Astro.props;
---

<section class="landing-section">
  <div class="landing-side reveal">
    <h2 class="landing-side-en">{eyebrow}</h2>
    <div class="ts-text is-secondary">{descriptor}</div>
  </div>
  <div class="landing-body landing-rows">
    <slot />
  </div>
  <div class="landing-more reveal">
    <a class="landing-side-link" href={viewAll}>
      {t["landing.allPosts"]} <span aria-hidden="true">↗</span>
    </a>
  </div>
</section>
