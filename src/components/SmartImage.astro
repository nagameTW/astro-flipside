---
// One image element for both source kinds the data layer accepts: a local
// asset (ImageMetadata import — rendered through astro:assets with a
// responsive srcset and webp) or a remote https:// / public/ path string
// (plain <img>, served untouched). Callers pass widths/sizes for the
// asset case; the string branch drops those srcset-only props.
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { resolveImg } from "@/utils/url";

interface Props extends Record<string, unknown> {
  src: ImageMetadata | string;
  alt: string;
  widths?: number[];
  sizes?: string;
  densities?: number[];
}
const { src, alt, widths, sizes, densities, ...common } = Astro.props;
---

{
  typeof src === "string" ? (
    <img src={resolveImg(src)} alt={alt} {...common} />
  ) : (
    <Image
      src={src}
      alt={alt}
      format="webp"
      widths={widths}
      sizes={sizes}
      densities={densities}
      {...common}
    />
  )
}
