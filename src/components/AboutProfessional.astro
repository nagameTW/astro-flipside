---
import SITE from "@/config";
import { AVATAR_WORK, PROFILE, PROFESSIONAL_SECTIONS } from "@/data/about";
import FaceToggle from "@/components/FaceToggle.astro";
import Section from "@/components/Section.astro";
import { url } from "@/utils/url";

// Work face keeps exactly one social affordance: the SITE.github link.
// Template users who want LinkedIn, email, etc. on this face should add a
// `links` section block instead (see src/components/blocks/Links.astro).
---

<!-- `is-hidden` + `inert` ship statically: personal is the default face, so
     this one must be hidden before any JS runs (no flash of the résumé). -->
<div class="about-layout face is-hidden" data-face="professional" inert>
  <aside class="about-aside ts-box about-card">
    <div class="ts-content">
      <img
        class="about-avatar"
        src={url(AVATAR_WORK)}
        width="136"
        height="136"
        alt=""
      />
      <div class="ts-header is-large is-heavy has-top-spaced">
        {PROFILE.name}
      </div>
      <div class="ts-text is-secondary">{PROFILE.headline}</div>
      <div class="social-icons has-top-spaced">
        <a
          class="ts-button is-icon is-circular"
          href={SITE.github}
          aria-label="GitHub"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="ts-icon is-github-icon"></span>
        </a>
      </div>
      <FaceToggle />
    </div>
  </aside>

  <div class="about-main">
    {PROFESSIONAL_SECTIONS.map((s) => <Section section={s} />)}
  </div>
</div>
