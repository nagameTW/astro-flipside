---
import SITE from "@/config";
import { AVATAR_WORK, PROFILE, PROFESSIONAL_SECTIONS } from "@/data/about";
import FaceToggle from "@/components/FaceToggle.astro";
import Section from "@/components/Section.astro";
import { url } from "@/utils/url";

// Work face renders SITE.socialsWork with the same url/copy affordances as
// the Life face (AboutPersonal.astro also hosts the shared clipboard
// handler — it targets [data-copy] document-wide, so copy buttons work on
// both faces). Longer link lists belong in a `links` section block instead
// (see src/components/blocks/Links.astro).
const isExternal = (u: string) => u.startsWith("http");
---

<!-- `is-hidden` + `inert` ship statically: personal is the default face, so
     this one must be hidden before any JS runs (no flash of the résumé). -->
<div class="about-layout face is-hidden" data-face="professional" inert>
  <aside class="about-aside ts-box about-card">
    <div class="ts-content">
      <img
        class="about-avatar"
        src={url(AVATAR_WORK)}
        width="136"
        height="136"
        alt=""
      />
      <div class="ts-header is-large is-heavy has-top-spaced">
        {PROFILE.name}
      </div>
      <div class="ts-text is-secondary">{PROFILE.headline}</div>
      <div class="social-icons has-top-spaced">
        {
          SITE.socialsWork.map((l) =>
            l.url ? (
              <a
                class="ts-button is-icon is-circular"
                href={l.url}
                aria-label={l.name}
                target={isExternal(l.url) ? "_blank" : undefined}
                rel={isExternal(l.url) ? "noopener noreferrer" : undefined}
              >
                <span class={`ts-icon ${l.icon}`} />
              </a>
            ) : (
              <button
                type="button"
                class="ts-button is-icon is-circular"
                data-copy={l.copy}
                aria-label={l.name}
              >
                <span class={`ts-icon ${l.icon}`} />
              </button>
            ),
          )
        }
      </div>
      <FaceToggle />
    </div>
  </aside>

  <div class="about-main">
    {PROFESSIONAL_SECTIONS.map((s) => <Section section={s} />)}
  </div>
</div>
