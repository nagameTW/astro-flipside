---
// The single owner of every section's chrome: the empty-data guard, the
// ts-box shell, and the heading. Blocks render ONLY their content — nine
// copies of the same shell used to live in blocks/* and drifted.
import type { Section } from "@/data/sections";
import Text from "@/components/blocks/Text.astro";
import Chips from "@/components/blocks/Chips.astro";
import Kv from "@/components/blocks/Kv.astro";
import Timeline from "@/components/blocks/Timeline.astro";
import Highlights from "@/components/blocks/Highlights.astro";
import Cards from "@/components/blocks/Cards.astro";
import Stats from "@/components/blocks/Stats.astro";
import Links from "@/components/blocks/Links.astro";
import Markdown from "@/components/blocks/Markdown.astro";

interface Props {
  section: Section;
}
const { section } = Astro.props;
const blocks = {
  text: Text,
  chips: Chips,
  kv: Kv,
  timeline: Timeline,
  highlights: Highlights,
  cards: Cards,
  stats: Stats,
  links: Links,
  markdown: Markdown,
} as const;
const Block = blocks[section.type];

// Empty data ⇒ the whole section (box and heading included) disappears —
// one rule for every block type, per the spec.
const isEmpty = (s: Section): boolean => {
  switch (s.type) {
    case "text":
      return s.paragraphs.length === 0;
    case "chips":
      return s.items.length === 0;
    case "kv":
      return s.rows.length === 0;
    case "timeline":
    case "highlights":
      return s.entries.length === 0;
    case "cards":
      return s.cards.length === 0;
    case "stats":
      return s.tiles.length === 0;
    case "links":
      return s.links.length === 0;
    case "markdown":
      return s.body.trim() === "";
  }
};

// The text block heads with `h1`: both faces' "About" section is the
// page's de facto h1. Every other block heads with h2.
const Heading = section.type === "text" ? "h1" : "h2";
---

{
  !isEmpty(section) && (
    <section class="ts-box">
      <div class="ts-content">
        {section.title && (
          <Heading class="ts-header is-large is-heavy">
            {section.title}
            <span class="ts-divider" />
          </Heading>
        )}
        {/* Each block's own Props type is checked everywhere it's used
            directly; TS just can't dependently-type "the props matching
            this union member's own variant" through a lookup-by-
            discriminant, so the spread needs the cast. */}
        <Block {...(section as any)} />
      </div>
    </section>
  )
}
