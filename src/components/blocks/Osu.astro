---
// osu!mania module — rank tiles above the chart, pp/time/accuracy below.
// An inactive account reports null ranks and pp 0 — those tiles drop
// instead of rendering "#null" / a misleading "0pp".
import { OSU } from "@/data/gamestats";
import { t, fill } from "@/locales";
import OsuRankChart from "@/components/OsuRankChart.astro";

type Tile = { label: string; value: string };
const isTile = (tile: Tile | false): tile is Tile => Boolean(tile);
const OSU_RANKS = OSU
  ? [
      OSU.globalRank != null && {
        label: t["osu.worldRank"],
        value: `#${OSU.globalRank.toLocaleString()}`,
      },
      OSU.countryRank != null && {
        label: t["osu.countryRank"],
        value: `#${OSU.countryRank.toLocaleString()}`,
      },
    ].filter(isTile)
  : [];
const OSU_STATS = OSU
  ? [
      OSU.pp > 0 && { label: "PP", value: OSU.pp.toLocaleString() },
      {
        label: t["osu.totalTime"],
        value: fill(t["life.hours"], { h: OSU.playTimeHours.toLocaleString() }),
      },
      { label: t["osu.accuracy"], value: `${OSU.accuracy}%` },
    ].filter(isTile)
  : [];
---

{
  OSU_STATS.length > 0 && (
    <section class="ts-box">
      <div class="ts-content">
        <h2 class="ts-header is-large is-heavy">
          osu!mania
          <span class="ts-divider" />
        </h2>
        {OSU_RANKS.length > 0 && (
          <div class="stat-grid">
            {OSU_RANKS.map((s) => (
              <div>
                <div class="ts-text is-secondary">{s.label}</div>
                <div class="ts-text is-bold">{s.value}</div>
              </div>
            ))}
          </div>
        )}
        <OsuRankChart />
        {OSU_STATS.length > 0 && (
          <div class="stat-grid">
            {OSU_STATS.map((s) => (
              <div>
                <div class="ts-text is-secondary">{s.label}</div>
                <div class="ts-text is-bold">{s.value}</div>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  )
}
