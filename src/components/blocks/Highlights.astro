---
// Dated single-line achievements: competitions, teaching, trainings,
// community — same `.aside`/`.indicator` timeline structure as Timeline.astro
// but with a single grouped-year label (markYears) instead of a start/end
// pair, and no duties/entry-note. Shell, heading, and empty-guard live in
// Section.astro.
import type { HighlightEntry } from "@/data/sections";
import { markYears } from "@/utils/timeline";
import Icon from "@/components/Icon.astro";

interface Props {
  entries: HighlightEntry[];
}
const { entries } = Astro.props;
const ROWS = markYears(entries, (e) => e.date);
---

<div class="ts-timeline">
  {
    ROWS.map(({ item: e, year }) => (
      <div class="item">
        <div class="aside ts-text is-description">{year}</div>
        <div class="indicator">
          <Icon name="trophy" />
        </div>
        <div class="content">
          <div class="ts-text is-bold">{e.title}</div>
          {e.subtitle && <div class="ts-text is-secondary">{e.subtitle}</div>}
        </div>
      </div>
    ))
  }
</div>
