---
// Plain tag row — interests (Life) and skills (Work) both use this exact
// markup today. Shell, heading, and empty-guard live in Section.astro.
interface Props {
  items: string[];
}
const { items } = Astro.props;
---

<div class="ts-wrap">
  {items.map((i) => <div class="ts-chip is-circular is-outlined">{i}</div>)}
</div>
