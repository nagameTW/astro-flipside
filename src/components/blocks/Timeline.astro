---
// Work-experience-shaped timeline: a two-line period (start / "– end"), an
// icon indicator, and an optional `duties` note block (bold name +
// paragraph, divided when there's more than one). Every current usage
// (experience/education/project history) reproduces exactly through this
// one shape:
//  - experience: has `end`, one or more named duties
//  - education: has `end`, at most one duty whose `name` carries the
//    "thesis title" line (empty `text` when there's no description)
//  - project experience: no `end` (bare year), a single nameless duty (its
//    `name` is "", so the bold line is skipped and only the paragraph shows)
import type { TimelineEntry } from "@/data/sections";

interface Props {
  title?: string;
  entries: TimelineEntry[];
}
const { title, entries } = Astro.props;
---

{
  entries.length > 0 && (
    <section class="ts-box">
      <div class="ts-content">
        {title && (
          <h2 class="ts-header is-large is-heavy">
            {title}
            <span class="ts-divider" />
          </h2>
        )}
        <div class="ts-timeline">
          {entries.map((e) => (
            <div class="item">
              <div class="aside ts-text is-description">
                <div>{e.start}</div>
                {e.end && <div>– {e.end}</div>}
              </div>
              <div class="indicator">
                <span class="ts-icon is-briefcase-icon" />
              </div>
              <div class="content">
                <div class="ts-text is-bold">{e.title}</div>
                {e.subtitle && (
                  <div class="ts-text is-secondary">{e.subtitle}</div>
                )}
                {e.duties && e.duties.length > 0 && (
                  <div class="entry-note">
                    {e.duties.map((d, i) => (
                      <>
                        {i > 0 && <div class="ts-divider is-section" />}
                        {d.name && <div class="ts-text is-bold">{d.name}</div>}
                        {d.text && <p class="ts-text is-secondary">{d.text}</p>}
                      </>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
