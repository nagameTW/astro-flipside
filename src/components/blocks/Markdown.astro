---
// Free-form Markdown body, for content that doesn't fit any other block.
// Heading markup matches the other blocks' (Text/Chips/etc.), not the
// abbreviated sketch this was specced from.
import { marked } from "marked";

interface Props {
  title?: string;
  body: string;
}
const { title, body } = Astro.props;
const html = marked.parse(body) as string;
---

<section class="ts-box">
  <div class="ts-content">
    {
      title && (
        <h2 class="ts-header is-large is-heavy">
          {title}
          <span class="ts-divider" />
        </h2>
      )
    }
    <div class="md-content" set:html={html} />
  </div>
</section>
