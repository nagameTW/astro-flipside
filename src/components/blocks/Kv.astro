---
// Label/value cards — extracted from the Life face's gear grid. Rows may
// carry an optional per-row `icon` (the gear grid's case) and an optional
// `href` that makes the WHOLE card the link (e.g. to a store page);
// grid/card/label classes and spacing are unchanged either way.
interface Props {
  title?: string;
  rows: { label: string; value: string; icon?: string; href?: string }[];
}
const { title, rows } = Astro.props;
const isExternal = (u: string) => u.startsWith("http");
---

{
  rows.length > 0 && (
    <section class="ts-box">
      <div class="ts-content">
        {title && (
          <h2 class="ts-header is-large is-heavy">
            {title}
            <span class="ts-divider" />
          </h2>
        )}
        <div class="gear-grid">
          {rows.map((row) => {
            const Card = row.href ? "a" : "div";
            return (
              <Card
                class="gear-card"
                href={row.href}
                target={
                  row.href && isExternal(row.href) ? "_blank" : undefined
                }
                rel={
                  row.href && isExternal(row.href)
                    ? "noopener noreferrer"
                    : undefined
                }
              >
                {row.icon && <span class={`ts-icon ${row.icon}`} />}
                <div class="gear-body">
                  <div class="gear-label ts-text is-secondary">
                    {row.label}
                  </div>
                  <div class="ts-text is-bold">{row.value}</div>
                </div>
              </Card>
            );
          })}
        </div>
      </div>
    </section>
  )
}
