---
// Label/value cards — extracted from the Life face's gear grid. Rows may
// carry an optional per-row `icon` (a name from Icon.astro's ICONS map,
// the gear grid's case) and an optional `href` that makes the WHOLE card
// the link (e.g. to a store page).
// Shell, heading, and empty-guard live in Section.astro.
import Icon from "@/components/Icon.astro";
import { isExternal } from "@/utils/url";

interface Props {
  rows: { label: string; value: string; icon?: string; href?: string }[];
}
const { rows } = Astro.props;
---

<div class="gear-grid">
  {
    rows.map((row) => {
      const Card = row.href ? "a" : "div";
      return (
        <Card
          class="gear-card"
          href={row.href}
          target={row.href && isExternal(row.href) ? "_blank" : undefined}
          rel={
            row.href && isExternal(row.href) ? "noopener noreferrer" : undefined
          }
        >
          {row.icon && <Icon name={row.icon} />}
          <div class="gear-body">
            <div class="gear-label ts-text is-secondary">{row.label}</div>
            <div class="ts-text is-bold">{row.value}</div>
          </div>
        </Card>
      );
    })
  }
</div>
