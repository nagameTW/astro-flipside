---
// Merges the trophy-wall grid (image-or-placeholder card + caption, click
// lightbox) with a generic clickable card (title/subtitle, wraps in a link
// when `url` is set). Precedence per card: `url` set → link; else `img` set
// → lightbox button (today's trophy behavior); else a plain, non-interactive
// placeholder card (e.g. certifications, which have neither).
// Shell, heading, and empty-guard live in Section.astro; `title` is still
// received here because the modal ids are namespaced by it.
import type { CardEntry } from "@/data/sections";
import { resolveImg } from "@/utils/url";

interface Props {
  title?: string;
  cards: CardEntry[];
}
const { title, cards } = Astro.props;
const isExternal = (u?: string) => !!u && u.startsWith("http");
// Modal ids must be unique across the whole page — both faces (and every
// Cards usage on them) are in the DOM at once — so they're namespaced by
// this block's own title rather than a bare per-card index. HTML ids allow
// any non-whitespace character, so only whitespace needs collapsing — a
// CJK-only title (e.g. "專業認證") stays distinct instead of collapsing to
// a single placeholder the way an ASCII-only filter would.
const slug = (title ?? "cards").replace(/\s+/g, "-");
---

<div class="trophy-grid">
  {
    cards.map((c, i) => {
      const media = c.img ? (
        <img src={resolveImg(c.img)} alt="" loading="lazy" />
      ) : (
        <div class="trophy-empty" />
      );
      const caption = (
        <>
          <div class="trophy-caption ts-text is-tiny is-secondary">
            {c.title}
          </div>
          {c.subtitle && (
            <div class="ts-text is-tiny is-secondary">{c.subtitle}</div>
          )}
        </>
      );
      return c.url ? (
        <a
          class="trophy-item is-link"
          href={c.url}
          target={isExternal(c.url) ? "_blank" : undefined}
          rel={isExternal(c.url) ? "noopener noreferrer" : undefined}
        >
          {media}
          {caption}
        </a>
      ) : c.img ? (
        <button
          type="button"
          class="trophy-item"
          data-modal={`card-modal-${slug}-${i}`}
        >
          {media}
          {caption}
        </button>
      ) : (
        <div>
          {media}
          {caption}
        </div>
      );
    })
  }
</div>
{/* In-page lightboxes: Tocas modals on the native <dialog>. Backdrop
    click and Esc close them. Only cards with an image and no `url` get
    one (the trophy-wall case). */}
{
  cards.map(
    (c, i) =>
      !c.url &&
      c.img && (
        <dialog
          class="ts-modal trophy-modal"
          id={`card-modal-${slug}-${i}`}
          aria-label={c.title}
        >
          <div class="content">
            <img src={resolveImg(c.img)} alt="" loading="lazy" />
          </div>
        </dialog>
      ),
  )
}

<script>
  import { wireModalOpeners } from "@/utils/dialogs";
  // Opening is the shared wiring (queries the whole document, so any number
  // of Cards instances work); closing stays here — in a Tocas ts-modal the
  // dialog element itself IS the dimmed overlay, so a click that lands on
  // it (not the content box) closes. Esc is native.
  wireModalOpeners(".trophy-item[data-modal]");
  document
    .querySelectorAll<HTMLDialogElement>("dialog.trophy-modal")
    .forEach((d) => {
      d.addEventListener("click", (e) => {
        if (e.target === d) d.close();
      });
    });
</script>
