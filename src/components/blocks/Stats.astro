---
// Tile row — reuses the shared stat-grid classes (label on top, bold value
// below), just driven by a generic tiles array. Shell, heading, and
// empty-guard live in Section.astro.
interface Props {
  tiles: { value: string; label: string }[];
}
const { tiles } = Astro.props;
---

<div class="stat-grid">
  {
    tiles.map((s) => (
      <div>
        <div class="ts-text is-secondary">{s.label}</div>
        <div class="ts-text is-bold">{s.value}</div>
      </div>
    ))
  }
</div>
