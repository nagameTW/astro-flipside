---
// A plain list of links with an optional trailing note — e.g. a talk or
// publication. External http(s) links open in a new tab. Shell, heading,
// and empty-guard live in Section.astro.
import { isExternal } from "@/utils/url";

interface Props {
  links: { label: string; url: string; note?: string }[];
}
const { links } = Astro.props;
---

<ul class="links-list">
  {
    links.map((l) => (
      <li>
        <a
          href={l.url}
          target={isExternal(l.url) ? "_blank" : undefined}
          rel={isExternal(l.url) ? "noopener noreferrer" : undefined}
        >
          {l.label}
        </a>
        {l.note && <span class="ts-text is-secondary">{l.note}</span>}
      </li>
    ))
  }
</ul>
