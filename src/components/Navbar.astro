---
import SITE from "@/config";
import Search from "@/components/Search.astro";
import Icon from "@/components/Icon.astro";
import { t } from "@/locales";
import { url } from "@/utils/url";

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  const target = url(href);
  // Astro's root-of-base pathname omits the trailing slash that url("/")
  // always has (e.g. "/astro-flipside" vs. "/astro-flipside/") — accept
  // either so the home link still lights up at the site root.
  return href === "/"
    ? pathname === target || `${pathname}/` === target
    : pathname.startsWith(target);
};
---

<header class="site-header" transition:persist>
  <div class="ts-container">
    <div class="inner">
      <a class="ts-header is-heavy" href={url("/")}>{SITE.title}</a>
      <nav>
        <div class="ts-tab is-pilled">
          {
            SITE.nav.map((link) => (
              <a
                class:list={["item", { "is-active": isActive(link.href) }]}
                href={url(link.href)}
              >
                {t[link.label]}
              </a>
            ))
          }
        </div>
        <button
          id="search-open"
          class="ts-button is-ghost is-icon is-circular"
          aria-label={t["search.open"]}
        >
          <Icon name="magnifying-glass" />
        </button>
        <button
          id="theme-toggle"
          class="ts-button is-ghost is-icon is-circular"
          aria-label={t["nav.themeToggle"]}
        >
          <Icon name="moon" class="has-hidden-dark" />
          <Icon name="sun" class="has-hidden-light" />
        </button>
      </nav>
    </div>
  </div>
  {/* Inside the sticky header on purpose: the panel hangs off the header's
      bottom edge (absolute, top:100%) so it reads as the header extending
      downward, at the header's z-level. */}
  <Search />
</header>
{/* Click-catching dim layer for the search panel. Lives OUTSIDE the header
    because .site-header's backdrop-filter would trap a position:fixed child;
    z 99 keeps it one notch under the header, so header + panel stay crisp
    while the page dims. */}
<div
  id="search-veil"
  class="search-veil"
  aria-hidden="true"
  hidden
  transition:persist
>
</div>

<script>
  // The header persists across ClientRouter navigations (transition:persist),
  // so its server-rendered active tab would stay stuck on the first page's
  // route. Recompute it on every navigation. Mirrors isActive() above: the
  // home link matches the site root exactly (trailing-slash tolerant), the
  // rest match by path prefix.
  const norm = (p: string) => p.replace(/\/+$/, "") || "/";
  const root = norm(import.meta.env.BASE_URL);
  const syncActive = () => {
    const here = norm(location.pathname);
    document
      .querySelectorAll<HTMLAnchorElement>(".site-header .ts-tab .item")
      .forEach((a) => {
        const target = norm(new URL(a.href).pathname);
        a.classList.toggle(
          "is-active",
          target === root
            ? here === target
            : here === target || here.startsWith(target + "/"),
        );
      });
  };
  document.addEventListener("astro:page-load", syncActive);
</script>

<script is:inline>
  // Delegated so it survives ClientRouter swaps (the button is a fresh
  // element on every page; inline scripts don't re-run).
  document.addEventListener("click", (e) => {
    if (!e.target.closest || !e.target.closest("#theme-toggle")) return;
    const html = document.documentElement;
    const isDark =
      html.classList.contains("is-dark") ||
      (!html.classList.contains("is-light") &&
        window.matchMedia("(prefers-color-scheme: dark)").matches);
    html.classList.toggle("is-dark", !isDark);
    html.classList.toggle("is-light", isDark);
    localStorage.setItem("theme", isDark ? "light" : "dark");
    window.dispatchEvent(new CustomEvent("themechange"));
  });
</script>
