---
// One numbered row in a landing preview section — shared by the Blog and
// Projects previews (index.astro). The whole row is the link; an external
// href (a project's repo) opens in a new tab, an internal one (a post)
// stays in-tab. Hover grows the title underline via .u-line.
import { isExternal } from "@/utils/url";

interface Props {
  /** 1-based position, shown as a zero-padded index (01, 02…). */
  n: number;
  title: string;
  description?: string;
  /** Absolute href — internal paths already run through url(). */
  href: string;
  /** Reveal-stagger index (see .reveal in global.css). */
  ri?: number;
}
const { n, title, description, href, ri = 0 } = Astro.props;
const ext = isExternal(href);
---

<a
  class="landing-row reveal"
  style={`--ri: ${ri}`}
  href={href}
  target={ext ? "_blank" : undefined}
  rel={ext ? "noopener noreferrer" : undefined}
>
  <div class="landing-row-top ts-text is-secondary">
    <span>{String(n).padStart(2, "0")}</span>
  </div>
  <div class="ts-header is-large is-heavy u-line">{title}</div>
  {description && <p class="ts-text is-secondary">{description}</p>}
</a>
