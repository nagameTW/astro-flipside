---
// Currently unused by any page (the portfolio /projects/ route is retired
// until there's real content to show — see src/data/projects.ts); kept as
// a worked example consumers can re-enable.
import type { Project } from "@/data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div class="ts-box">
  <div class="ts-content">
    <div class="ts-header is-heavy">{project.name}</div>
    <p class="ts-text is-secondary">{project.description}</p>
    <div class="ts-wrap">
      {
        project.tech.map((t) => (
          <div class="ts-chip is-circular is-outlined">{t}</div>
        ))
      }
    </div>
    <a
      class="ts-button is-outlined is-start-icon"
      href={project.url}
      target="_blank"
      rel="noopener noreferrer"
    >
      <span class="ts-icon is-github-icon"></span> GitHub
    </a>
  </div>
</div>
