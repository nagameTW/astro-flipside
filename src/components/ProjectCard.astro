---
// One project on /projects/ — a borderless content block (the Medium
// look, per owner). The WHOLE block is the link, same as a blog row:
// hover underlines the title, zooms the cover, and turns the arrow.
import type { Project } from "@/data/projects";
import SmartImage from "@/components/SmartImage.astro";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<a
  class="project-item"
  href={project.url}
  target="_blank"
  rel="noopener noreferrer"
>
  {
    project.img && (
      <div class="project-item-cover">
        <SmartImage
          src={project.img}
          alt=""
          loading="lazy"
          widths={[400, 800]}
          sizes="(max-width: 767px) 94vw, 370px"
        />
      </div>
    )
  }
  <div class="ts-header is-heavy">{project.name}</div>
  <p class="ts-text is-secondary">{project.description}</p>
  <div class="ts-wrap">
    {
      project.tech.map((t) => (
        <div class="ts-chip is-circular is-outlined">{t}</div>
      ))
    }
  </div>
  <span class="project-item-link">GitHub <span aria-hidden="true">↗</span></span>
</a>
