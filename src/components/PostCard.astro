---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";
import { resolveImg, url } from "@/utils/url";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

{
  /* Medium-style list card: title tied to the cover's top edge,
     description in the middle, date tied to the bottom edge (the body is
     a space-between column matched to the cover height). Tags live on the
     post page, not here. The title is a stretched link, so the whole card
     is clickable (.post-card-link::after in global.css). */
}
<div
  class:list={["ts-box", "post-card", { "has-cover": !!post.data.heroImage }]}
>
  <div class="ts-content">
    <div class="post-card-body">
      <div class="ts-header is-heavy">
        <a class="post-card-link" href={url(`/blog/${post.id}/`)}
          >{post.data.title}</a
        >
      </div>
      {
        post.data.description && (
          <p class="ts-text is-secondary">{post.data.description}</p>
        )
      }
      <div class="ts-text is-description">
        <FormattedDate date={post.data.pubDate} />
      </div>
    </div>
    {
      post.data.heroImage && (
        <img
          class="post-card-cover"
          src={resolveImg(post.data.heroImage)}
          alt=""
          loading="lazy"
        />
      )
    }
  </div>
</div>
