---
// One shared zoom lightbox for every content image site-wide: post hero
// banners and images inside any markdown body (.md-content). Gallery and
// trophy walls keep their richer per-item dialogs (captions from data,
// arrow nav); avatars and post-card covers are deliberately NOT zoomable —
// the avatar is identity chrome, and a card cover click already navigates.
// Reuses the gallery-modal styles wholesale (full-viewport dark stage,
// letterboxed figure, reserved caption line).
import { t } from "@/locales";
---

<dialog id="image-lightbox" class="gallery-modal" aria-label={t["lightbox.label"]}>
  <figure class="gallery-modal-figure">
    <img src="" alt="" />
    <figcaption class="ts-text is-secondary"></figcaption>
  </figure>
</dialog>

<script>
  const dialog = document.getElementById("image-lightbox") as HTMLDialogElement;
  const img = dialog.querySelector("img")!;
  const caption = dialog.querySelector("figcaption")!;
  // Delegated so it covers images in any page's markdown without per-image
  // wiring. Images inside links keep their link behavior; images already
  // inside a dialog (gallery/trophy lightboxes) are excluded.
  document.addEventListener("click", (e) => {
    const el = e.target as Element;
    if (!(el instanceof HTMLImageElement)) return;
    if (!el.matches(".md-content img, .post-hero")) return;
    if (el.closest("a, dialog")) return;
    img.src = el.currentSrc || el.src;
    img.alt = el.alt;
    caption.textContent = el.alt;
    dialog.showModal();
  });
  // Same X/FB-style dismissal as the gallery: click anywhere closes
  // (Esc comes free with showModal).
  dialog.addEventListener("click", () => dialog.close());
</script>
