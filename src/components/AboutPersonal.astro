---
import SITE from "@/config";
import FaceToggle from "@/components/FaceToggle.astro";
import Section from "@/components/Section.astro";
import { url } from "@/utils/url";
import { AVATAR, PERSONAL_SECTIONS } from "@/data/life";

// The casual "personal" side — the default face. Social buttons are
// config-driven (SITE.socials): entries with `url` link out, entries with
// `copy` (e.g. Discord, which has no add-friend URL) copy the handle to
// the clipboard instead — see the script below.
const isExternal = (href?: string) => !!href && href.startsWith("http");
---

<div class="about-layout face" data-face="personal">
  <aside class="about-aside ts-box about-card">
    <div class="ts-content">
      <img
        class="about-avatar"
        src={url(AVATAR)}
        width="136"
        height="136"
        alt=""
      />
      <div class="ts-header is-large is-heavy has-top-spaced">
        {SITE.title}
      </div>
      <!-- Invisible stand-in for the Work card's subtitle line: both cards
           must keep identical geometry or the cross-fade reads as the card
           shifting and flickering (removing the Work card's subtitle line
           exposed this). -->
      <div class="ts-text is-secondary" aria-hidden="true">&nbsp;</div>
      <div class="social-icons has-top-spaced">
        {
          SITE.socials.map((l) =>
            l.url ? (
              <a
                class="ts-button is-icon is-circular"
                href={l.url}
                aria-label={l.name}
                target={isExternal(l.url) ? "_blank" : undefined}
                rel={isExternal(l.url) ? "noopener noreferrer" : undefined}
              >
                <span class={`ts-icon ${l.icon}`} />
              </a>
            ) : (
              <button
                type="button"
                class="ts-button is-icon is-circular"
                data-copy={l.copy}
                aria-label={l.name}
              >
                <span class={`ts-icon ${l.icon}`} />
              </button>
            ),
          )
        }
      </div>
      <FaceToggle />
    </div>
  </aside>

  <div class="about-main">
    {PERSONAL_SECTIONS.map((s) => <Section section={s} />)}
  </div>
</div>

<script>
  import { t } from "@/locales";

  // Discord has no add-friend URL — copy the username to the clipboard and
  // flash a confirmation in the tooltip (aria-label drives the CSS tooltip).
  document
    .querySelectorAll<HTMLElement>(".social-icons [data-copy]")
    .forEach((btn) => {
      btn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.copy!);
          const prev = btn.getAttribute("aria-label")!;
          btn.setAttribute("aria-label", t["life.copied"]);
          setTimeout(() => btn.setAttribute("aria-label", prev), 1500);
        } catch {
          /* clipboard blocked — the username still shows in the tooltip */
        }
      });
    });
</script>
