---
// The post-list scaffold shared by the blog index and every tag page:
// heading + count row, the responsive card grid, an empty state, and
// pagination. One layout, two routes.
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { t, fill } from "@/locales";

interface Props {
  page: Page<CollectionEntry<"blog">>;
  title: string;
}
const { page, title } = Astro.props;
---

<div class="section-title">
  <h1 class="ts-header is-big is-heavy">{title}</h1>
  <span class="ts-text is-description"
    >{fill(t["blog.count"], { n: page.total })}</span
  >
</div>
{
  page.total === 0 ? (
    <p class="ts-text is-secondary">{t["blog.empty"]}</p>
  ) : (
    <div class="cards-grid is-wide">
      {page.data.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  )
}
<Pagination page={page} />
