---
// The site-wide footer: the landing's brand-dark closing band, promoted.
// Full-bleed dark, Say-hello heading, the url-type social buttons, and
// the copyright line. A real <footer> so every page keeps a contentinfo
// landmark.
import SITE from "@/config";
import Icon from "@/components/Icon.astro";
import { t } from "@/locales";

const year = new Date().getFullYear();
const isExternal = (u: string) => u.startsWith("http");
---

<footer class="footer-band reveal">
  <div class="ts-container">
    <h2 class="landing-side-en">{t["landing.enHello"]}</h2>
    <p class="footer-band-line">{t["landing.hello"]}</p>
    <div class="footer-band-links">
      {
        SITE.socials.map((l) =>
          l.url ? (
            <a
              class="ts-button is-icon is-circular"
              href={l.url}
              aria-label={l.name}
              target={isExternal(l.url) ? "_blank" : undefined}
              rel={isExternal(l.url) ? "noopener noreferrer" : undefined}
            >
              <Icon name={l.icon} />
            </a>
          ) : null
        )
      }
    </div>
    <p class="footer-band-copyright">© {year} {SITE.title}</p>
  </div>
</footer>
