---
import Layout from "@/layouts/Layout.astro";
import { GALLERY } from "@/data/gallery";
import { t, fill } from "@/locales";
import { resolveImg } from "@/utils/url";
import sharp from "sharp";

// Width/height attributes keep the masonry from reflowing as photos load
// (this page measured CLS 0.188 without them). Local files are measured
// once at build; remote URLs are skipped and keep their natural flow.
const dims = new Map<string, { width: number; height: number }>();
for (const photo of GALLERY) {
  if (/^https?:\/\//.test(photo.src)) continue;
  const meta = await sharp(`public${photo.src}`).metadata();
  if (meta.width && meta.height)
    dims.set(photo.src, { width: meta.width, height: meta.height });
}
// The masonry carries data-pagefind-body: captions and alt text are unique
// content, so the gallery joins the search index (see index.astro's note;
// the lightbox copies below the masonry stay out of it).
---

<Layout title={t["nav.gallery"]} description={t["gallery.description"]}>
  <div class="section-title">
    <h1 class="ts-header is-big is-heavy">{t["nav.gallery"]}</h1>
    <span class="ts-text is-description"
      >{fill(t["gallery.count"], { n: GALLERY.length })}</span
    >
  </div>
  {
    GALLERY.length === 0 ? (
      <p class="ts-text is-secondary">{t["gallery.empty"]}</p>
    ) : (
      <div
        class="gallery-masonry"
        data-pagefind-body
        data-pagefind-meta={`title:${t["nav.gallery"]}`}
      >
        {GALLERY.map((photo, i) => (
          <button
            type="button"
            class="gallery-item"
            data-modal={`gallery-modal-${i}`}
          >
            <img
              src={resolveImg(photo.src)}
              alt={photo.alt}
              loading={i < 2 ? "eager" : "lazy"}
              width={dims.get(photo.src)?.width}
              height={dims.get(photo.src)?.height}
            />
            {photo.caption && (
              <div class="gallery-caption ts-text is-tiny">
                {photo.caption}
              </div>
            )}
          </button>
        ))}
      </div>
    )
  }
  {
    // In-page lightboxes, same shape as Cards.astro's trophy wall. Ids are
    // index-based rather than slugified from text, so they stay unique and
    // valid no matter what language alt/caption is written in.
    GALLERY.map((photo, i) => (
      <dialog
        class="gallery-modal"
        id={`gallery-modal-${i}`}
        aria-label={photo.alt}
      >
        <button
          type="button"
          class="gallery-nav is-prev"
          data-open={`gallery-modal-${(i - 1 + GALLERY.length) % GALLERY.length}`}
          aria-label={t["gallery.prev"]}
        >
          <span class="ts-icon is-angle-left-icon" />
        </button>
        <figure class="gallery-modal-figure">
          <img src={resolveImg(photo.src)} alt="" loading="lazy" />
          <figcaption class="ts-text is-secondary">
            {photo.caption ?? ""}
          </figcaption>
        </figure>
        <button
          type="button"
          class="gallery-nav is-next"
          data-open={`gallery-modal-${(i + 1) % GALLERY.length}`}
          aria-label={t["gallery.next"]}
        >
          <span class="ts-icon is-angle-right-icon" />
        </button>
      </dialog>
    ))
  }
</Layout>

<script>
  import { wireModalOpeners } from "@/utils/dialogs";
  // Opening is the shared wiring (same as Cards.astro's trophy wall);
  // the stage-specific close and arrow-nav behavior stays below.
  wireModalOpeners(".gallery-item[data-modal]");
  document.querySelectorAll<HTMLButtonElement>(".gallery-nav").forEach((nav) => {
    nav.addEventListener("click", () => {
      const target = nav.dataset.open && document.getElementById(nav.dataset.open);
      if (!(target instanceof HTMLDialogElement)) return;
      nav.closest("dialog")?.close();
      target.showModal();
    });
  });
  document
    .querySelectorAll<HTMLDialogElement>("dialog.gallery-modal")
    .forEach((d) => {
      d.addEventListener("click", (e) => {
        // The whole dialog is the dark stage; clicking anywhere off the
        // image, its caption, or the nav arrows closes, X/FB style.
        if (!(e.target as Element).closest(".gallery-modal-figure, .gallery-nav"))
          d.close();
      });
      // Arrow keys walk the wall (wrapping at both ends), same as the
      // on-stage chevrons.
      d.addEventListener("keydown", (e) => {
        const dir =
          e.key === "ArrowRight" ? ".is-next" : e.key === "ArrowLeft" ? ".is-prev" : null;
        if (dir) (d.querySelector(dir) as HTMLButtonElement | null)?.click();
      });
    });
</script>
