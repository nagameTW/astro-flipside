---
// The portfolio page: a grid of ProjectCard entries from src/data/projects.
// Empty data hides the grid and shows the empty note, same policy as every
// data-driven surface.
import Layout from "@/layouts/Layout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { PROJECTS } from "@/data/projects";
import { t } from "@/locales";
---

<Layout title={t["nav.projects"]} description={t["projects.description"]}>
  <div class="section-title">
    <h1 class="ts-header is-big is-heavy">{t["nav.projects"]}</h1>
  </div>
  {
    PROJECTS.length === 0 ? (
      <p class="ts-text is-secondary">{t["projects.empty"]}</p>
    ) : (
      <div class="projects-grid">
        {PROJECTS.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    )
  }
</Layout>
