---
// The portfolio page: a paginated grid of ProjectCard entries from
// src/data/projects (SITE.pageSize.projects per page — 9 fills the 3-up
// grid three rows deep). Empty data hides the grid and shows the empty
// note, same policy as every data-driven surface.
import type { GetStaticPaths, Page } from "astro";
import Layout from "@/layouts/Layout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import Pagination from "@/components/Pagination.astro";
import { PROJECTS, type Project } from "@/data/projects";
import SITE from "@/config";
import { t } from "@/locales";

export const getStaticPaths = (async ({ paginate }) =>
  paginate(PROJECTS, {
    pageSize: SITE.pageSize.projects,
  })) satisfies GetStaticPaths;

const { page } = Astro.props as { page: Page<Project> };
---

<Layout title={t["nav.projects"]} description={t["projects.description"]}>
  <div class="section-title reveal">
    <h1 class="ts-header is-big is-heavy">{t["nav.projects"]}</h1>
  </div>
  {
    page.data.length === 0 ? (
      <p class="ts-text is-secondary">{t["projects.empty"]}</p>
    ) : (
      <div class="projects-grid">
        {page.data.map((project, i) => (
          <div class="reveal" style={`--ri: ${i % 3}`}>
            <ProjectCard project={project} />
          </div>
        ))}
      </div>
    )
  }
  <Pagination page={page} />
</Layout>
