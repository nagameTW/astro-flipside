---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { getPosts } from "@/utils/posts";
import { t, fill } from "@/locales";

export const getStaticPaths = (async ({ paginate }) =>
  paginate(await getPosts(), { pageSize: 6 })) satisfies GetStaticPaths;

const { page } = Astro.props as { page: Page<CollectionEntry<"blog">> };
---

<Layout title={t["blog.title"]} description={t["blog.listDescription"]}>
  <div class="section-title">
    <h1 class="ts-header is-big is-heavy">{t["blog.title"]}</h1>
    <span class="ts-text is-description"
      >{fill(t["blog.count"], { n: page.total })}</span
    >
  </div>
  {
    page.total === 0 ? (
      <p class="ts-text is-secondary">{t["blog.empty"]}</p>
    ) : (
      <div class="cards-grid is-wide">
        {page.data.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    )
  }
  <Pagination page={page} />
</Layout>
