---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostList from "@/components/PostList.astro";
import { getPosts } from "@/utils/posts";
import { t } from "@/locales";

export const getStaticPaths = (async ({ paginate }) =>
  paginate(await getPosts(), { pageSize: 6 })) satisfies GetStaticPaths;

const { page } = Astro.props as { page: Page<CollectionEntry<"blog">> };
---

<Layout title={t["blog.title"]} description={t["blog.listDescription"]}>
  <PostList page={page} title={t["blog.title"]} />
</Layout>
