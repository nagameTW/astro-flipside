---
import { type CollectionEntry, render } from "astro:content";
import BlogPost from "@/layouts/BlogPost.astro";
import { getPosts } from "@/utils/posts";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: { post, next: posts[i - 1], prev: posts[i + 1] },
  }));
}
type Props = {
  post: CollectionEntry<"blog">;
  // List is newest-first: "previous" is the older post (index + 1), "next"
  // is the newer one (index - 1).
  prev?: CollectionEntry<"blog">;
  next?: CollectionEntry<"blog">;
};

const { post, prev, next } = Astro.props;
const { Content, remarkPluginFrontmatter, headings } = await render(post);
---

<BlogPost
  {...post.data}
  minutesRead={remarkPluginFrontmatter.minutesRead}
  headings={headings}
  prev={prev && { id: prev.id, title: prev.data.title }}
  next={next && { id: next.id, title: next.data.title }}
>
  <Content />
</BlogPost>
