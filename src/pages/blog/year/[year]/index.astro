---
// Year filter pages: /blog/year/2026/ lists that year's posts, no
// pagination (a year rarely outgrows one screenful; the rail is the
// navigation).
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostList from "@/components/PostList.astro";
import { getPosts } from "@/utils/posts";
import { t, fill } from "@/locales";

export const getStaticPaths = (async () => {
  const posts = await getPosts();
  const years = [...new Set(posts.map((p) => p.data.pubDate.getFullYear()))];
  return years.map((year) => ({
    params: { year: String(year) },
    props: {
      year,
      posts: posts.filter((p) => p.data.pubDate.getFullYear() === year),
    },
  }));
}) satisfies GetStaticPaths;

const { year, posts } = Astro.props as {
  year: number;
  posts: CollectionEntry<"blog">[];
};
const title = fill(t["blog.yearTitle"], { year });
---

<Layout title={title} description={t["blog.listDescription"]}>
  <PostList posts={posts} title={title} activeYear={year} />
</Layout>
