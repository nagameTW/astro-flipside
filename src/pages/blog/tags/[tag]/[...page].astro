---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostList from "@/components/PostList.astro";
import { getPosts } from "@/utils/posts";
import { t, fill } from "@/locales";
import SITE from "@/config";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getPosts();
  const tags = new Set(posts.flatMap((post) => post.data.tags));
  return [...tags].flatMap((tag) =>
    paginate(
      posts.filter((post) => post.data.tags.includes(tag)),
      { params: { tag }, pageSize: SITE.pageSize.blog },
    ),
  );
}) satisfies GetStaticPaths;

const { tag } = Astro.params as { tag: string };
const { page } = Astro.props as { page: Page<CollectionEntry<"blog">> };
const title = fill(t["blog.taggedWith"], { tag });
---

<Layout title={title} description={t["blog.tagIndexDescription"]}>
  <PostList page={page} title={title} activeTag={tag} />
</Layout>
