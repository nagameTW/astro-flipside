---
// Landing page, redesigned after the owner's reference (nagi-6tu — a
// Japanese corporate-minimal look): a big left-aligned wordmark hero in
// whitespace, one large rounded photo, then sections with a sticky
// bilingual label rail on the left (big English word, small locale line,
// an arrow link) and the content flowing on the right. Projects render
// as numbered rows, and a dark brand-colored card closes the page with
// the social links. Scroll entrances come from the site-wide .reveal
// machinery in Layout.
import Layout from "@/layouts/Layout.astro";
import SmartImage from "@/components/SmartImage.astro";
import LandingSection from "@/components/LandingSection.astro";
import LandingRow from "@/components/LandingRow.astro";
import SITE from "@/config";
import { PROJECTS } from "@/data/projects";
import { GALLERY } from "@/data/gallery";
import { getPosts } from "@/utils/posts";
import { t } from "@/locales";
import { url } from "@/utils/url";
import { Image } from "astro:assets";
// The repo's own README hero — the site collage the owner composed.
import heroPhoto from "../../docs/hero.jpg";

const latest = (await getPosts()).slice(0, SITE.pageSize.home);
const photos = GALLERY.slice(0, SITE.pageSize.home);
const projects = PROJECTS.slice(0, SITE.pageSize.home);
---

<Layout description={SITE.description} hideBackToTop>
  <section class="landing-hero">
    <h1 class="landing-title">
      {
        t["landing.tagline"]
          .split("\n")
          .map((line, i) => (
            <span class="landing-title-line reveal" style={`--ri: ${i}`}>
              {line}
            </span>
          ))
      }
    </h1>
  </section>

  <div class="landing-photo-hero reveal" style="--ri: 2">
    <Image
      src={heroPhoto}
      alt=""
      widths={[900, 1600, 2400]}
      sizes="(max-width: 1220px) 96vw, 1180px"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <p class="landing-intro reveal" style="--ri: 3">{SITE.description}</p>

  <section class="landing-section is-tinted is-stacked">
    <div class="landing-side reveal" style="--ri: 0">
      <h2 class="landing-side-en">{t["landing.enAbout"]}</h2>
      <div class="ts-text is-secondary">{t["landing.aboutLabel"]}</div>

    </div>
    <div class="landing-body">
      <p class="landing-blurb reveal" style="--ri: 1">{t["landing.aboutBlurb"]}</p>
    </div>
  </section>

  {
    latest.length > 0 && (
      <LandingSection
        eyebrow={t["landing.enBlog"]}
        descriptor={t["landing.latest"]}
        viewAll={url("/blog/")}
      >
        {latest.map((post, i) => (
          <LandingRow
            n={i + 1}
            ri={i + 1}
            title={post.data.title}
            description={post.data.description}
            href={url(`/blog/${post.id}/`)}
          />
        ))}
      </LandingSection>
    )
  }

  {
    photos.length > 0 && (
      <section class="landing-section is-tinted">
        <div class="landing-side reveal">
          <h2 class="landing-side-en">{t["landing.enGallery"]}</h2>
          <div class="ts-text is-secondary">{t["nav.gallery"]}</div>
        </div>
        <a class="landing-body landing-gallery" href={url("/gallery/")}>
          {photos.map((photo, i) => (
            <div class="landing-photo reveal" style={`--ri: ${i + 1}`}>
              <SmartImage
                src={photo.src}
                alt={photo.alt}
                loading="lazy"
                widths={[400, 800]}
                sizes="(max-width: 767px) 46vw, 280px"
              />
            </div>
          ))}
        </a>
        <div class="landing-more reveal">
          <a class="landing-side-link" href={url("/gallery/")}>
            {t["landing.allPosts"]} <span aria-hidden="true">↗</span>
          </a>
        </div>
      </section>
    )
  }

  {
    projects.length > 0 && (
      <LandingSection
        eyebrow={t["landing.enProjects"]}
        descriptor={t["nav.projects"]}
        viewAll={url("/projects/")}
      >
        {projects.map((project, i) => (
          <LandingRow
            n={i + 1}
            ri={i + 1}
            title={project.name}
            description={project.description}
            href={project.url}
          />
        ))}
      </LandingSection>
    )
  }
</Layout>
