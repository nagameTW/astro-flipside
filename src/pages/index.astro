---
// Landing page — the coin standing on its edge. The visitor picks a face:
// the Work card deep-links to /about/?face=work, the Life card to /about/
// (Life is the about page's default). Below the fold: the three latest
// posts. Prototype: layout and copy are up for owner iteration.
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import SITE from "@/config";
import { AVATAR } from "@/data/life";
import { AVATAR_WORK, PROFILE } from "@/data/about";
import { getPosts } from "@/utils/posts";
import { t } from "@/locales";
import { url } from "@/utils/url";
import { Image } from "astro:assets";

const latest = (await getPosts()).slice(0, 3);
---

<Layout description={SITE.description}>
  <section class="landing-hero">
    <h1 class="ts-header is-massive is-heavy">{SITE.title}</h1>
    <p class="ts-text is-secondary landing-tagline">{t["landing.tagline"]}</p>
  </section>

  <div class="landing-faces">
    <a class="landing-card" href={url("/about/?face=work")}>
      <Image
        src={AVATAR_WORK}
        alt=""
        width={160}
        densities={[1, 2]}
        loading="eager"
      />
      <div class="landing-card-name ts-header is-large is-heavy">
        {PROFILE.name}
      </div>
      {
        PROFILE.headline && (
          <div class="ts-text is-secondary">{PROFILE.headline}</div>
        )
      }
      <span class="landing-card-face ts-text is-bold">{t["face.work"]}</span>
    </a>
    <a class="landing-card" href={url("/about/")}>
      <Image src={AVATAR} alt="" width={160} densities={[1, 2]} loading="eager" />
      <div class="landing-card-name ts-header is-large is-heavy">
        {SITE.title}
      </div>
      <span class="landing-card-face ts-text is-bold">{t["face.life"]}</span>
    </a>
  </div>

  {
    latest.length > 0 && (
      <section class="landing-latest">
        <div class="section-title">
          <h2 class="ts-header is-big is-heavy">{t["landing.latest"]}</h2>
          <a class="ts-text is-secondary" href={url("/blog/")}>
            {t["landing.allPosts"]}
          </a>
        </div>
        <div class="cards-grid is-wide">
          {latest.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </section>
    )
  }
</Layout>
